# ---------------------------------------------------------------
# Autocell Backend - Variáveis de ambiente
# Copia este ficheiro para ".env" e preenche com os teus valores.
# NUNCA faças commit do ficheiro ".env" real.
# ---------------------------------------------------------------

# URI de ligação ao MongoDB (MongoDB Atlas, Render, etc.)
MONGODB_URI=mongodb://localhost:27017/autocell

# Porta onde a API vai ouvir (no Render costuma ser injetada automaticamente)
PORT=5000
